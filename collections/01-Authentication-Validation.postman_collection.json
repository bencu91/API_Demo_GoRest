{
  "info": {
    "_postman_id": "7b656755-7ce1-4041-b6ca-c69c6eb7873f",
    "name": "GoRest - Authorization level",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "41661217"
  },
  "item": [
    {
      "name": "Auth Validation - Invalid Token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 401 Unauthorized\", () => {\r",
              "    pm.response.to.have.status(401);\r",
              "});\r",
              "\r",
              "pm.test(\"Json response has message property\", () => {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property('message');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "InvalidToken",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Auth Validation - Valid Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 with valid token\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is under 2000ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains properties\", () => {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    json.forEach((user) => {\r",
              "    pm.expect(user).to.have.property('id');\r",
              "    pm.expect(user).to.have.property('name');\r",
              "    pm.expect(user).to.have.property('email');\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Returns array of users\", () => {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type is application/json\", () => {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is a non-empty list\", () => {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an('array').and.not.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{authToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    }
  ]
}