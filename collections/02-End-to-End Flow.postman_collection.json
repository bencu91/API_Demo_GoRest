              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Response has required post fields', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json).to.have.property('user_id');",
              "    pm.expect(json).to.have.property('title');",
              "    pm.expect(json).to.have.property('body');",
              "});",
              "",
              "pm.test('Post fields have correct types', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.id).to.be.a('number');",
              "    pm.expect(json.user_id).to.be.a('number');",
              "    pm.expect(json.title).to.be.a('string');",
              "    pm.expect(json.body).to.be.a('string');",
              "});",
              "",
              "pm.test('Post is linked to the created user', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.user_id).to.eql(pm.environment.get('userId'));",
              "});",
              "",
              "const post_id = pm.response.json().id;",
              "pm.environment.set(\"postId\",post_id)"
