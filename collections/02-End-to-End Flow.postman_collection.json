      "name": "Step 1 - Create User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('newUserName', 'E2E Test');",
              "pm.collectionVariables.set('newUserEmail', 'e2e_' + Date.now() + '@testmail.com');",
              "pm.collectionVariables.set('newUserGender', 'male');",
              "pm.collectionVariables.set('newUserStatus', 'active');"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Response time is under 2000ms', () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test('Status code is 201 Created', () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response is valid JSON', () => {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test('Content-Type is application/json', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Response has required user fields', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json).to.have.property('name');",
              "    pm.expect(json).to.have.property('email');",
              "    pm.expect(json).to.have.property('gender');",
              "    pm.expect(json).to.have.property('status');",
              "});",
              "",
              "pm.test('Created user data matches request payload', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.name).to.eql('E2E Test');",
              "    pm.expect(json.gender).to.eql('male');",
              "    pm.expect(json.status).to.eql('active');",
              "});",
              "",
              "const userId = pm.response.json().id;",
              "pm.environment.set(\"userId\", userId);",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
